{
	"name": "svelte_ssr_template",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev --port 8200",
		"build": "vite build && php build.php",
		"preview": "vite preview & start http://localhost:4173",
		"prepare": "svelte-kit sync || echo ''",
		"view-php": "cd .svelte-kit/output/client && php -S localhost:8000",
		"view-prerender": "cd .svelte-kit/output/prerendered && php -S localhost:8500 & start http://localhost:8500"
	},
	"devDependencies": {
		"@sveltejs/adapter-auto": "^7.0.1",
		"@sveltejs/kit": "^2.63.0",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"html-minifier-terser": "^7.2.0",
		"sass": "^1.101.0",
		"svelte": "^5.56.1",
		"vite": "^8.0.16"
	}
}
